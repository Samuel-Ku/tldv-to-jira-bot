# Telegram Bot (обов'язково)
# Отримайте токен у @BotFather: https://t.me/botfather
TELEGRAM_BOT_TOKEN=your-token-from-botfather

# ID користувачів, яким дозволено користуватись ботом (через кому)
# Залиште порожнім щоб дозволити всім
# Дізнатись свій ID: https://t.me/userinfobot
TELEGRAM_ALLOWED_IDS=123456789,987654321

# ── LLM API налаштування ────────────────────────────────────────

# OpenAI-compatible API endpoint
LLM_API_BASE=http://100.122.55.28:20130/v1

# API Key для доступу до LLM
LLM_API_KEY=sk-82a552949eeb0b01-x9ww5n-0f0957dc

# Назва моделі (free-stack — робоча модель для аналізу)
LLM_MODEL=free-stack

# ── Jira API налаштування (опціонально) ──────────────────────────
# Базовий URL вашого Jira інстансу
JIRA_BASE_URL=https://your-domain.atlassian.net

# Email користувача Jira
JIRA_EMAIL=your-email@example.com

# API Token (створіть тут: https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_API_TOKEN=your-api-token

# Ключ проекту (наприклад: PROJ, DEV, SCRUM)
JIRA_PROJECT_KEY=PROJ
